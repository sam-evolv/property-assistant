{
  "buildCommand": "npm --workspace=@openhouse/unified-portal run build",
  "installCommand": "npm ci --workspace=@openhouse/unified-portal --workspace=@openhouse/api --workspace=@openhouse/db --workspace=@openhouse/core --workspace=@openhouse/auth --workspace=@openhouse/ui --workspace=@openhouse/workers --include-workspace-root=false",
  "framework": "nextjs",
  "outputDirectory": "apps/unified-portal/.next",
  "crons": [
    {
      "path": "/api/cron/refresh-tokens",
      "schedule": "0 0 * * *"
    },
    {
      "path": "/api/cron/send-scheduled-broadcasts",
      "schedule": "0 0 * * *"
    }
  ]
}
