# ═══════════════════════════════════════════════════════════════════════════
# OPENHOUSE AI UNIFIED PORTAL - ENVIRONMENT VARIABLES
# ═══════════════════════════════════════════════════════════════════════════
# Copy this file to .env.local and fill in values

# ═══════════════════════════════════════════════════════════════════════════
# SUPABASE (Required)
# ═══════════════════════════════════════════════════════════════════════════
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ═══════════════════════════════════════════════════════════════════════════
# BACKUP ENCRYPTION (Required for production)
# ═══════════════════════════════════════════════════════════════════════════
# Generate with: openssl rand -hex 32
BACKUP_ENCRYPTION_KEY=your-32-byte-hex-key-here

# ═══════════════════════════════════════════════════════════════════════════
# BACKBLAZE B2 STORAGE (Primary backup destination)
# ═══════════════════════════════════════════════════════════════════════════
BACKUP_STORAGE=b2
B2_ENDPOINT=https://s3.us-west-004.backblazeb2.com
B2_KEY_ID=your-b2-key-id
B2_APPLICATION_KEY=your-b2-application-key
B2_BUCKET_NAME=your-bucket-name

# ═══════════════════════════════════════════════════════════════════════════
# AWS S3 STORAGE (Alternate backup destination)
# ═══════════════════════════════════════════════════════════════════════════
# Uncomment to use S3 instead of B2
# BACKUP_STORAGE=s3
# AWS_ACCESS_KEY_ID=your-aws-access-key
# AWS_SECRET_ACCESS_KEY=your-aws-secret-key
# AWS_BUCKET_NAME=your-s3-bucket
# AWS_REGION=us-east-1

# ═══════════════════════════════════════════════════════════════════════════
# SLACK ALERTING (Required for production monitoring)
# ═══════════════════════════════════════════════════════════════════════════
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/xxx/yyy/zzz

# ═══════════════════════════════════════════════════════════════════════════
# STAGING/DRILL DATABASE (For restore drills)
# ═══════════════════════════════════════════════════════════════════════════
# Leave empty to use local Docker PostgreSQL for drills
# STAGING_DATABASE_URL=postgresql://user:pass@staging-host:5432/staging_db

# ═══════════════════════════════════════════════════════════════════════════
# DESTRUCTIVE OPERATIONS GATE
# ═══════════════════════════════════════════════════════════════════════════
# These must be explicitly set to enable destructive operations
# NEVER set these in production unless performing authorized maintenance
# ALLOW_DESTRUCTIVE_OPS=true
# DESTRUCTIVE_OPS_SECRET=generate-a-random-secret

# ═══════════════════════════════════════════════════════════════════════════
# AI / OPENAI (Required for Care Chat)
# ═══════════════════════════════════════════════════════════════════════════
OPENAI_API_KEY=sk-your-openai-key-here

# ═══════════════════════════════════════════════════════════════════════════
# GOOGLE MAPS PLACES (Required for lettings address autocomplete)
# ═══════════════════════════════════════════════════════════════════════════
# Browser-side key — restrict in Google Cloud Console to:
#   - HTTP referrers: portal.openhouseai.ie, *.vercel.app (preview), localhost
#   - APIs: Maps JavaScript API + Places API
# Without this, /agent/lettings/properties/new degrades to manual address entry.
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=

# ═══════════════════════════════════════════════════════════════════════════
# FEATURE FLAGS
# ═══════════════════════════════════════════════════════════════════════════
# Assistant V2 image upload (Sprint 1). Default off in production.
# Enable for the Longview Estates and Solas Renewables demo tenants only
# during initial testing. When false, the attachment button does not render
# and the /api/assistant/* multimodal routes return 404.
FEATURE_ASSISTANT_IMAGE_UPLOAD=false
NEXT_PUBLIC_FEATURE_ASSISTANT_IMAGE_UPLOAD=false

# Assistant V2 builder-side snag app (Sprint 2). Default off in production.
# Enable per tenant during testing. When false, the /snag and
# /admin/snaggers routes 404 and all /api/snag/* server routes return 404
# before any auth or DB work.
FEATURE_BUILDER_SNAG_APP=false
NEXT_PUBLIC_FEATURE_BUILDER_SNAG_APP=false

# Internal key used to authorise the fire-and-forget enrichment fetch
# from /api/snag/create to /api/snag/enrich/[issue_report_id]. Must be a
# random opaque secret set per environment. Without it, enrichment is
# skipped (snag still gets created). Generate with: openssl rand -hex 32
INTERNAL_ENRICHMENT_KEY=

# ═══════════════════════════════════════════════════════════════════════════
# APPLICATION
# ═══════════════════════════════════════════════════════════════════════════
NODE_ENV=development
